[run]
source = ., bin
omit = 
    */tests/*
    */test_*
    */__pycache__/*
    */venv/*
    */.venv/*
    */load_test.py
    load_test.py
    setup.py
    */site-packages/*
    bin/main.tf
    bin/outputs.tf
    bin/variables.tf
    bin/packer.toml
    bin/README.md

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod