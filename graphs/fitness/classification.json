        "description": "Configurable input: The penalty applied per token used. Set to a negative value."
      }
    },
    {
      "id": "cycle_penalty_weight",
      "type": "CONST",
      "params": {
        "value": -0.01
      },
      "metadata": {
        "description": "Configurable input: The penalty applied per compute cycle. Set to a negative value."
      }
