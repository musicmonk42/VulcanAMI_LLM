    },
    {
      "from": {
        "node": "pat",
        "port": "pattern_out"
      },
      "to": {
        "node": "find",
        "port": "pattern_in"
      },
      "kind": "data"
    },
    {
      "from": {
        "node": "target_graph_input",
        "port": "value"
      },
      "to": {
        "node": "find",
