# ============================================================================
# Graphix / VulcanAMI Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Application Environment
# ----------------------------------------------------------------------------
FLASK_ENV=development  # Options: development, production
DEBUG=false            # Set to false in production!
APP_VERSION=1.3.0

# ----------------------------------------------------------------------------
# Security & Authentication
# ----------------------------------------------------------------------------
# JWT Secret (MUST be strong random string in production!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me-in-production
JWT_EXP_MINUTES=30
JWT_ISSUER=graphix-registry
JWT_AUDIENCE=graphix-agents
JWT_IDENTITY_CLAIM=sub

# Bootstrap key for initial admin/agent creation (one-time use)
BOOTSTRAP_KEY=your-bootstrap-key-change-me

# Enforce HTTPS for bootstrap endpoint (true in production!)
ENFORCE_HTTPS_BOOTSTRAP=true

# JWT Revocation
JWT_REVOCATION_PREFIX=jwt:revoked:
JWT_ENABLE_LOGOUT=true

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# SQLite (development)
DB_URI=sqlite:///graphix_registry.db

# PostgreSQL (production)
# DB_URI=postgresql://user:password@localhost:5432/graphix_db

# MySQL (alternative)
# DB_URI=mysql+pymysql://user:password@localhost:3306/graphix_db

# ----------------------------------------------------------------------------
# Redis (Required for Production)
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_LIMITER_DB=1

# Optional: Full Redis URL
# REDIS_URL=redis://localhost:6379/1

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
MAX_CONTENT_LENGTH_BYTES=16777216  # 16MB
IR_MAX_BYTES=2097152              # 2MB

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no wildcards in production!)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ----------------------------------------------------------------------------
# Nonce & Replay Protection
# ----------------------------------------------------------------------------
NONCE_TTL_SECONDS=300  # 5 minutes
MAX_ROLES=10

# ----------------------------------------------------------------------------
# Audit Logging
# ----------------------------------------------------------------------------
AUDIT_LOG_PATH=./logs/audit_log.jsonl
AUDIT_LOG_ROTATION=midnight        # Options: s, m, h, d, midnight
AUDIT_LOG_INTERVAL=1
AUDIT_LOG_MAX_SIZE=10485760       # 10MB
AUDIT_LOG_RETENTION=30            # Keep 30 rotated files
AUDIT_LOG_COMPRESSION=gzip        # Options: none, gzip
AUDIT_LOG_ENCRYPT=false           # Set true for encrypted audit logs
AUDIT_LOG_ENCRYPTION_KEY=your-encryption-key-if-enabled
AUDIT_LOG_BATCH_SIZE=100
AUDIT_LOG_BATCH_TIMEOUT=1.0
MAX_DETAILS_SIZE=1048576          # 1MB

# Valid event types (comma-separated, empty = all allowed)
VALID_EVENT_TYPES=

# ----------------------------------------------------------------------------
# DLT (Distributed Ledger) Integration
# ----------------------------------------------------------------------------
DLT_ANCHOR_CRITICAL=true
DLT_RETRY_COUNT=3
DLT_BATCH_SIZE=10

# ----------------------------------------------------------------------------
# Syslog Integration
# ----------------------------------------------------------------------------
# SYSLOG_FACILITY=16  # LOG_LOCAL0

# ----------------------------------------------------------------------------
# Async Logging
# ----------------------------------------------------------------------------
ASYNC_LOGGING=true

# ----------------------------------------------------------------------------
# Monitoring & Observability
# ----------------------------------------------------------------------------
# Prometheus metrics endpoint enabled
METRICS_ENABLED=true

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=graphix-registry

# ----------------------------------------------------------------------------
# Alerting
# ----------------------------------------------------------------------------
# Slack webhook for security alerts (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ----------------------------------------------------------------------------
# Agent Configuration
# ----------------------------------------------------------------------------
AGENT_ID=unknown_agent
HOSTNAME=

# ----------------------------------------------------------------------------
# OmniCore Integration (if used)
# ----------------------------------------------------------------------------
# OMNICORE_URL=https://api.example.com

# ----------------------------------------------------------------------------
# Additional Services
# ----------------------------------------------------------------------------
# Consul (service discovery)
# CONSUL_HOST=localhost
# CONSUL_PORT=8500

# ----------------------------------------------------------------------------
# Production Hardening
# ----------------------------------------------------------------------------
# Set these in production for enhanced security:
# - Use strong JWT_SECRET_KEY (64+ chars, random)
# - Use strong BOOTSTRAP_KEY (32+ chars, random)
# - Enable AUDIT_LOG_ENCRYPT=true
# - Set FLASK_ENV=production
# - Set DEBUG=false
# - Require HTTPS for all endpoints
# - Use PostgreSQL instead of SQLite
# - Ensure Redis is available (no fallback)
# - Enable Prometheus metrics
# - Configure Slack alerts
# - Set up log aggregation (ELK, Splunk)
# - Enable rate limiting per-user and per-IP
# - Review and minimize CORS_ORIGINS
# - Rotate secrets regularly
# ============================================================================
