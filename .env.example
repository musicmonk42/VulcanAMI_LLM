################################################################################
# VulcanAMI Environment Configuration Example
# Copy this file to .env and fill in the values
################################################################################

################################################################################
# API Keys (CRITICAL - Required for LLM features)
################################################################################

# OpenAI API Key (Required for chat features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-openai-key...

# Anthropic API Key (Optional - for Claude models)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# Graphix API Key (Optional - for Graphix services)
GRAPHIX_API_KEY=...your-graphix-key...

################################################################################
# JWT & Security Configuration (Required)
################################################################################

# JWT Secret Key (Required)
# Used for JWT token generation and validation
# Generate with: openssl rand -base64 48
# NOTE: This is a placeholder value only, not a real secret
JWT_SECRET_KEY=your-jwt-secret-key-here

# Graphix JWT Secret (used by api_server.py)
GRAPHIX_JWT_SECRET=${JWT_SECRET_KEY}

# Bootstrap Key (Required)
# Used for initial system bootstrap and authentication
# Generate with: openssl rand -base64 32
# NOTE: This is a placeholder value only, not a real secret
BOOTSTRAP_KEY=your-bootstrap-key-here

################################################################################
# Self-Improvement Configuration (Required for autonomous features)
################################################################################

# Main LLM API key for self-improvement (usually same as OPENAI_API_KEY)
VULCAN_LLM_API_KEY=${OPENAI_API_KEY}

# Enable self-improvement system (KILL SWITCH)
# Set to 0 to immediately disable all self-improvement features
# This prevents cost drain from runaway self-improvement loops
VULCAN_ENABLE_SELF_IMPROVEMENT=1

# Legacy enable flag (kept for backwards compatibility)
ENABLE_SELF_IMPROVEMENT=1

# Self-improvement loop check interval in seconds
# Default: 86400 (24 hours) - prevents excessive API costs
# For development/testing, you can lower this (e.g., 300 for 5 minutes)
# WARNING: Setting this too low can cause rapid cost accumulation!
SELF_IMPROVEMENT_INTERVAL=86400

# Minimum time between improvements in seconds
# Prevents infinite loops by enforcing a minimum cooldown
# Default: 3600 (1 hour)
SELF_IMPROVEMENT_MIN_INTERVAL=3600

# Intrinsic drives configuration
INTRINSIC_DRIVES_ENABLED=True
INTRINSIC_DRIVES_APPROVAL_REQUIRED=False
INTRINSIC_DRIVES_CHECK_INTERVAL=120
INTRINSIC_DRIVES_MAX_COST_SESSION=2.0
INTRINSIC_DRIVES_MAX_COST_DAY=10.0

################################################################################
# Database Configuration
################################################################################

# PostgreSQL Configuration (Required)
POSTGRES_DB=vulcanami
POSTGRES_USER=vulcanami
# Generate with: openssl rand -base64 32
# NOTE: This is a placeholder value only, not a real secret
POSTGRES_PASSWORD=your-postgres-password-here

# Database Connection
# NOTE: This is a placeholder value only, not a real secret
DATABASE_URL=postgresql://vulcanami:your-postgres-password-here@postgres:5432/vulcanami

################################################################################
# Redis Configuration
################################################################################

# Redis Password (Required)
# Generate with: openssl rand -base64 32
# NOTE: This is a placeholder value only, not a real secret
REDIS_PASSWORD=your-redis-password-here

# Redis Connection
# NOTE: This is a placeholder value only, not a real secret
REDIS_URL=redis://:your-redis-password-here@redis:6379/0

################################################################################
# Service Ports Configuration
################################################################################
# See docs/COMPLETE_SERVICE_CATALOG.md for full port allocation matrix
# To avoid conflicts, ensure different services use different ports

# Main platform
UNIFIED_PORT=8080                # Unified platform server (full_platform.py)

# Main application port (legacy)
PORT=8000

# Standalone services (avoid conflicts)
API_PORT=8000                    # API Gateway (api_gateway.py)
API_SERVER_PORT=8001             # Graphix API Server (api_server.py)
DQS_PORT=8083                    # Data Quality Service (changed from 8080 to avoid conflict)
PII_PORT=8082                    # PII Service (pii_service.py) - no conflict
LISTENER_PORT=8084               # Graph Listener (changed from 8181 to avoid conflict)

# Arena and Registry
ARENA_PORT=8181                  # Arena service (if running standalone)
REGISTRY_GRPC_PORT=50051         # Registry gRPC server

# Note: Services mounted in unified platform (VULCAN, Arena, Registry)
# share port 8080 with different URL paths (/vulcan, /arena, /registry)

################################################################################
# Storage Configuration (Optional - for production)
################################################################################

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
# Generate with: openssl rand -base64 24
# NOTE: This is a placeholder value only, not a real secret
MINIO_ROOT_PASSWORD=your-minio-password-here
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# S3 Configuration (Alternative to MinIO)
# S3_BUCKET=...
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

################################################################################
# Vulcan Memory System v46 Configuration
################################################################################

# AWS/S3 Configuration
# For AWS S3:
#   Set these credentials directly
# For MinIO/LocalStack:
#   Use MINIO_ROOT_USER/MINIO_ROOT_PASSWORD and set S3_ENDPOINT_URL
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_REGION=us-east-1
S3_BUCKET=vulcanami-memory
S3_ENDPOINT_URL=http://minio:9000

# Milvus Vector Database Configuration
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Packfile Storage Configuration
PACKFILE_SIZE_MB=32
COMPACTION_STRATEGY=adaptive
BLOOM_FILTER=true

# Index Configuration
INDEX_TYPE=disk_based_tier_c

# Unlearning Engine Configuration
UNLEARNING_METHOD=gradient_surgery

# ZK Prover Configuration
PROOF_SYSTEM=groth16

# Storage Paths
MEMORY_STORE_PATH=./memory_store
CACHE_ROOT=/tmp/vulcan_cache
CONFIG_PATH=./configs

################################################################################
# Platform Configuration
################################################################################

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO

# API Configuration
# SECURITY: Default to localhost (127.0.0.1) for secure binding
# Set to 0.0.0.0 only when needed for external access (Docker, K8s, Railway)
API_PORT=8000
API_HOST=127.0.0.1
HOST=127.0.0.1

# Unified Platform Configuration (for full_platform.py)
# These variables use the UNIFIED_ prefix as specified in full_platform.py
UNIFIED_HOST=127.0.0.1
UNIFIED_PORT=8000

################################################################################
# Grafana Configuration (Required for production monitoring)
################################################################################

# Generate with: openssl rand -base64 16
# NOTE: This is a placeholder value only, not a real secret
GRAFANA_PASSWORD=your-grafana-password-here

################################################################################
# Performance Optimization Configuration (VULCAN Simple Mode)
################################################################################
# These settings optimize VULCAN for fast chat responses and reduced CPU usage.
# Enable VULCAN_SIMPLE_MODE=true to automatically apply all performance optimizations.

# Enable Simple Mode - automatically sets all performance flags below
# When true: BERT skipping, reduced agent pool, bounded provenance
VULCAN_SIMPLE_MODE=false

# Skip BERT embeddings - use OpenAI directly (saves 3.5s+ per request)
# Set to true to bypass local BERT model loading
SKIP_BERT_EMBEDDINGS=false

# Use only OpenAI for inference (bypass local model)
OPENAI_ONLY_MODE=false

# Disable self-improvement for basic chat (saves API calls)
DISABLE_SELF_IMPROVEMENT=false

# Disable world model for faster responses
DISABLE_WORLD_MODEL=false

# Disable meta-reasoning for faster responses
DISABLE_META_REASONING=false

# Agent pool size (reduced in simple mode to save CPU)
# Default: 1/5 in simple mode, 10/100 otherwise
MIN_AGENTS=10
MAX_AGENTS=100

# Agent status check interval in seconds
# Increase to reduce CPU polling overhead
# Default: 300 (5 min) in simple mode, 30 otherwise
AGENT_CHECK_INTERVAL=30

# Maximum provenance records to keep (prevents memory leak)
# Default: 50 in simple mode, 1000 otherwise
MAX_PROVENANCE_RECORDS=1000

# Provenance TTL in seconds (default: 1 hour)
PROVENANCE_TTL_SECONDS=3600

################################################################################
# HuggingFace Model Security (Optional - for production)
################################################################################
# Pin HuggingFace models to specific commit hashes for security (CWE-494)
# Find revision hashes at: https://huggingface.co/<model-name>/commits/main
# Example: VULCAN_TEXT_MODEL_REVISION=86b5e0934494bd15c9632b12f734a8a67f723594
# VULCAN_TEXT_MODEL_REVISION=
# VULCAN_AUDIO_MODEL_REVISION=
# VULCAN_BERT_MODEL_REVISION=
# VULCAN_VISION_AUDIO_MODEL_REVISION=
# ADVERSARIAL_DETECTOR_REVISION=

################################################################################
# CuriosityDriver Configuration (Active Learning Heartbeat)
################################################################################
# Controls the autonomous curiosity-driven learning system
# The CuriosityDriver runs learning cycles in a separate process to avoid
# blocking the main event loop and causing high CPU usage

# Interval between heartbeat cycles (seconds)
# Default: 60.0 seconds
CURIOSITY_HEARTBEAT_INTERVAL=60.0

# Minimum exploration budget required to run a learning cycle
# If budget falls below this, driver sleeps instead of running
# Default: 10.0
CURIOSITY_MIN_BUDGET=10.0

# Maximum experiments to run per learning cycle
# Higher values = more thorough learning but longer cycles
# Default: 5
CURIOSITY_MAX_EXPERIMENTS=5

# Sleep duration when budget is low (seconds)
# When budget is below threshold, driver sleeps this long before rechecking
# Default: 120.0 seconds (2 minutes)
CURIOSITY_LOW_BUDGET_SLEEP=120.0

# Timeout for each learning cycle (seconds)
# If a cycle takes longer than this, it's cancelled
# Default: 300.0 seconds (5 minutes)
CURIOSITY_CYCLE_TIMEOUT=300.0

################################################################################
# Security Notes
################################################################################
# 1. NEVER commit .env files with real secrets to version control
# 2. Use strong, randomly generated passwords for all services
# 3. Rotate secrets regularly in production
# 4. Use secret management services (AWS Secrets Manager, HashiCorp Vault) in production
# 5. Ensure .env is listed in .gitignore
# 6. Network Binding: Default to 127.0.0.1 (localhost) for security
#    - Set API_HOST/HOST to 0.0.0.0 only in containerized environments
# 7. Model Pinning: Set HuggingFace model revision hashes in production
################################################################################
