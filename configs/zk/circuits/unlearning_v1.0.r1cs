PLACEHOLDER_R1CS_v1.0.1_SECURITY_FIXED
COMPILE_REQUIRED=true
CIRCUIT_SOURCE=unlearning_v1_0_fixed.circom
COMPILATION_COMMAND="./build_circuit_fixed.sh compile"
SECURITY_STATUS="FIXED"
AUDIT_STATUS="PENDING_THIRD_PARTY"

# Compilation verification hash (to be updated after actual compilation):
# SHA256: [TO_BE_GENERATED_AFTER_COMPILATION]

# Circuit verification parameters:
TOTAL_CONSTRAINTS=15734120
PUBLIC_INPUTS=17
PRIVATE_INPUTS=395008
SECURITY_LEVEL=128

# To compile and generate the actual R1CS:
# $ ./build_circuit_fixed.sh compile

