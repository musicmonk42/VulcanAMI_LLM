# ==============================================================================
# REDIS EXPORTER CONFIGURATION
# ==============================================================================
# Vulcan LLM Redis Metrics Exporter
# Version: 4.6.0
# Last Updated: 2025-11-14
# Documentation: https://github.com/oliver006/redis_exporter
# ==============================================================================

# ------------------------------------------------------------------------------
# REDIS CONNECTION SETTINGS
# ------------------------------------------------------------------------------

# Primary Redis instance
# SECURITY FIX: Updated to use TLS port
REDIS_ADDR=rediss://redis:6380

# Multiple Redis instances (comma-separated)
# REDIS_ADDR=rediss://redis-primary:6380,rediss://redis-replica-1:6380,rediss://redis-replica-2:6380

# Redis Sentinel configuration
# REDIS_ADDR=redis-sentinel://sentinel:26379
# REDIS_SENTINEL_MASTER_NAME=mymaster

# Redis Cluster configuration
# REDIS_ADDR=rediss://redis-cluster-node1:6380,rediss://redis-cluster-node2:6380,rediss://redis-cluster-node3:6380

# Redis password authentication
# SECURITY FIX: Added password authentication
REDIS_PASSWORD=VulcanAMI_Redis_Str0ng_P@ssw0rd_2025_!@#$%
# REDIS_PASSWORD_FILE=/run/secrets/redis_password

# Redis username (Redis 6+ ACL)
REDIS_USER=exporter_user

# TLS/SSL configuration
# SECURITY FIX: Enabled TLS configuration
REDIS_ADDR=rediss://redis:6380
REDIS_TLS_CERT_FILE=/etc/redis/certs/client-cert.pem
REDIS_TLS_KEY_FILE=/etc/redis/certs/client-key.pem
REDIS_TLS_CA_CERT_FILE=/etc/redis/certs/ca-cert.pem
REDIS_TLS_SERVER_NAME=redis.vulcanami.io
REDIS_TLS_SKIP_VERIFY=false

# Connection pool settings
REDIS_EXPORTER_CONNECTIONS_METRICS=true
REDIS_EXPORTER_CONNECTION_TIMEOUT=15s
REDIS_EXPORTER_SET_CLIENT_NAME=redis_exporter

# ------------------------------------------------------------------------------
# EXPORTER SERVER SETTINGS
# ------------------------------------------------------------------------------

# HTTP server binding
REDIS_EXPORTER_WEB_LISTEN_ADDRESS=:9121
REDIS_EXPORTER_WEB_TELEMETRY_PATH=/metrics

# TLS for exporter endpoint
REDIS_EXPORTER_TLS_SERVER_CERT_FILE=/etc/exporter/certs/server-cert.pem
REDIS_EXPORTER_TLS_SERVER_KEY_FILE=/etc/exporter/certs/server-key.pem
REDIS_EXPORTER_TLS_SERVER_CA_CERT_FILE=/etc/exporter/certs/ca-cert.pem
REDIS_EXPORTER_TLS_SERVER_MIN_VERSION=1.2

# ------------------------------------------------------------------------------
# METRIC COLLECTION SETTINGS
# ------------------------------------------------------------------------------

# Namespace for metrics (prefix)
REDIS_EXPORTER_NAMESPACE=vulcan

# Metric collection settings
REDIS_EXPORTER_CHECK_KEYS=*
REDIS_EXPORTER_CHECK_SINGLE_KEYS=
REDIS_EXPORTER_CHECK_STREAMS=
REDIS_EXPORTER_CHECK_SINGLE_STREAMS=

# Key patterns to check (comma-separated)
REDIS_EXPORTER_CHECK_KEY_PATTERNS=pack:pack-*,pack_bloom:pack-*,manifest:sha256:*,pin:shard:*,ids:*,doc:sha256:*,neg:sha256:*

# Key groups for detailed metrics
REDIS_EXPORTER_CHECK_KEY_GROUPS=packs=pack:*,blooms=pack_bloom:*,manifests=manifest:*,pins=pin:*,ids=ids:*,docs=doc:*,negative=neg:*

# Count keys per pattern
REDIS_EXPORTER_COUNT_KEYS=pack:pack-*,pack_bloom:pack-*,manifest:sha256:*,pin:shard:*

# Export key sizes
REDIS_EXPORTER_CHECK_KEY_GROUP_BATCH_SIZE=10000
REDIS_EXPORTER_MAX_DISTINCT_KEY_GROUPS=100

# Stream monitoring
REDIS_EXPORTER_CHECK_STREAMS=vulcan:events:*,vulcan:tasks:*,vulcan:logs:*
REDIS_EXPORTER_STREAM_KEYS=vulcan:events:indexing,vulcan:events:queries,vulcan:tasks:processing

# ------------------------------------------------------------------------------
# REDIS INFO SECTIONS
# ------------------------------------------------------------------------------

# Include all INFO sections (default)
REDIS_EXPORTER_INCL_SYSTEM_METRICS=true

# INFO sections to include (comma-separated)
# Available: Server,Clients,Memory,Persistence,Stats,Replication,CPU,Commandstats,Cluster,Keyspace,Modules
REDIS_EXPORTER_INFO_SECTIONS=Server,Clients,Memory,Persistence,Stats,Replication,CPU,Commandstats,Cluster,Keyspace

# ------------------------------------------------------------------------------
# SCRIPT AND LUA MONITORING
# ------------------------------------------------------------------------------

# Export Lua script metrics
REDIS_EXPORTER_IS_CLUSTER=false
REDIS_EXPORTER_IS_TILE38=false

# Custom Lua scripts to run for metrics
# REDIS_EXPORTER_SCRIPT=/path/to/custom_metrics.lua

# Script duration histogram buckets (seconds)
REDIS_EXPORTER_SCRIPT_DURATION_BUCKETS=0.001,0.005,0.01,0.05,0.1,0.5,1,5

# ------------------------------------------------------------------------------
# COMMAND AND SLOWLOG MONITORING
# ------------------------------------------------------------------------------

# Export per-command metrics
REDIS_EXPORTER_EXPORT_CLIENT_LIST=true
REDIS_EXPORTER_EXPORT_CLIENT_PORT=false

# Slowlog monitoring
REDIS_EXPORTER_CHECK_SLOWLOG=true
REDIS_EXPORTER_SLOWLOG_MAX_LEN=128

# Latency monitoring
REDIS_EXPORTER_LATENCY_HISTOGRAM=true
REDIS_EXPORTER_LATENCY_BUCKETS=0.001,0.002,0.005,0.01,0.025,0.05,0.1,0.25,0.5,1,2.5,5,10

# ------------------------------------------------------------------------------
# MEMORY AND KEY ANALYSIS
# ------------------------------------------------------------------------------

# Memory usage sampling
REDIS_EXPORTER_INCLUDE_MEMORY_USAGE_STATS=true
REDIS_EXPORTER_MEMORY_SAMPLES=100

# Key analysis
REDIS_EXPORTER_SKIP_TLS_VERIFICATION=false
REDIS_EXPORTER_SET_CLIENT_NAME=true

# ------------------------------------------------------------------------------
# PERFORMANCE AND OPTIMIZATION
# ------------------------------------------------------------------------------

# Scraping behavior
REDIS_EXPORTER_PING_ON_CONNECT=true
REDIS_EXPORTER_INCL_CONFIG_METRICS=true

# Redis config metrics
# SECURITY FIX: Updated to use renamed CONFIG command
REDIS_EXPORTER_CONFIG_COMMAND=CONFIG_VULCAN_SECURE_2025

# Disable expensive metrics in high-load scenarios
# REDIS_EXPORTER_SKIP_EXPENSIVE_METRICS=false

# ------------------------------------------------------------------------------
# KEYSPACE DATABASE SELECTION
# ------------------------------------------------------------------------------

# Scan all databases (default)
# REDIS_EXPORTER_CHECK_KEYS_BATCH_SIZE=1000

# Specific databases to monitor (comma-separated, empty = all)
# REDIS_EXPORTER_DB=0,1,2

# ------------------------------------------------------------------------------
# LOGGING AND DEBUGGING
# ------------------------------------------------------------------------------

# Log format: logfmt, json, text
REDIS_EXPORTER_LOG_FORMAT=json

# Log level: debug, info, warn, error
REDIS_EXPORTER_DEBUG=false
REDIS_EXPORTER_LOG_LEVEL=info

# Verbose logging for debugging
# REDIS_EXPORTER_DEBUG_VERBOSE=false

# Redis commands logging (warning: high volume)
# REDIS_EXPORTER_LOG_REDIS_COMMANDS=false

# ------------------------------------------------------------------------------
# SECURITY AND ACCESS CONTROL
# ------------------------------------------------------------------------------

# Skip certificate verification (not recommended for production)
REDIS_EXPORTER_SKIP_TLS_VERIFICATION=false

# Client certificates for mutual TLS
REDIS_EXPORTER_CLIENT_CERT=/etc/redis/certs/client-cert.pem
REDIS_EXPORTER_CLIENT_KEY=/etc/redis/certs/client-key.pem

# ------------------------------------------------------------------------------
# PROMETHEUS INTEGRATION
# ------------------------------------------------------------------------------

# Metric prefixes and labels
REDIS_EXPORTER_REDIS_METRICS_ONLY=false
REDIS_EXPORTER_INCL_SYSTEM_METRICS=true

# Add constant labels to all metrics
REDIS_EXPORTER_CONST_LABELS=environment=production,cluster=vulcan-primary,region=us-east-1,tier=cache

# ------------------------------------------------------------------------------
# ADVANCED FEATURES
# ------------------------------------------------------------------------------

# Export Redis instance info as labels
REDIS_EXPORTER_EXPORT_INSTANCE_INFO=true

# Export build info
REDIS_EXPORTER_INCLUDE_BUILD_INFO=true

# Export exporter metrics
REDIS_EXPORTER_INCLUDE_EXPORTER_METRICS=true

# Export Go runtime metrics
REDIS_EXPORTER_INCLUDE_GO_RUNTIME_METRICS=true

# ------------------------------------------------------------------------------
# SENTINEL SPECIFIC SETTINGS
# ------------------------------------------------------------------------------

# Sentinel metrics (if using Sentinel)
# REDIS_EXPORTER_SENTINEL_MASTER_NAME=mymaster
# REDIS_EXPORTER_SENTINEL_ADDR=sentinel-1:26379,sentinel-2:26379,sentinel-3:26379

# ------------------------------------------------------------------------------
# CLUSTER SPECIFIC SETTINGS
# ------------------------------------------------------------------------------

# Cluster metrics (if using Redis Cluster)
REDIS_EXPORTER_IS_CLUSTER=false
# REDIS_EXPORTER_CLUSTER_ADDR=cluster-node-1:6379,cluster-node-2:6379,cluster-node-3:6379

# ------------------------------------------------------------------------------
# RATE LIMITING AND THROTTLING
# ------------------------------------------------------------------------------

# Prevent overwhelming Redis with metric collection
# REDIS_EXPORTER_TIMEOUT=10s
# REDIS_EXPORTER_MAX_CONNECTIONS=10

# ------------------------------------------------------------------------------
# CUSTOM METRICS AND EXTENSIONS
# ------------------------------------------------------------------------------

# Tile38 specific metrics (if using Tile38)
REDIS_EXPORTER_IS_TILE38=false

# Custom metric scripts
# REDIS_EXPORTER_SCRIPT_PATH=/etc/redis/exporter/scripts

# ------------------------------------------------------------------------------
# HEALTH CHECK CONFIGURATION
# ------------------------------------------------------------------------------

# Health check endpoint
# HTTP GET /health returns 200 if Redis is reachable
# Useful for Kubernetes liveness/readiness probes

# ------------------------------------------------------------------------------
# VULCAN-SPECIFIC METRICS
# ------------------------------------------------------------------------------

# Application-specific key patterns for Vulcan LLM
VULCAN_PACK_KEYS=pack:pack-*
VULCAN_BLOOM_KEYS=pack_bloom:pack-*
VULCAN_MANIFEST_KEYS=manifest:sha256:*
VULCAN_PIN_KEYS=pin:shard:*
VULCAN_ID_KEYS=ids:*:*:sig-*
VULCAN_DOC_KEYS=doc:sha256:*
VULCAN_NEGATIVE_KEYS=neg:sha256:*

# Export detailed metrics for Vulcan key patterns
VULCAN_DETAILED_METRICS=true
VULCAN_TRACK_KEY_TTL=true
VULCAN_TRACK_KEY_SIZE=true
VULCAN_TRACK_MEMORY_FRAGMENTATION=true

# ------------------------------------------------------------------------------
# MONITORING INTEGRATION
# ------------------------------------------------------------------------------

# Integration with monitoring systems
MONITORING_SYSTEM=prometheus
METRICS_RETENTION_DAYS=90

# Alert thresholds (for external alerting systems)
ALERT_MEMORY_USAGE_THRESHOLD=90
ALERT_EVICTION_RATE_THRESHOLD=1000
ALERT_LATENCY_P99_THRESHOLD=100
ALERT_CONNECTION_USAGE_THRESHOLD=90

# ------------------------------------------------------------------------------
# BACKUP AND DISASTER RECOVERY METRICS
# ------------------------------------------------------------------------------

# Track RDB/AOF metrics
TRACK_PERSISTENCE_METRICS=true
TRACK_REPLICATION_LAG=true
TRACK_SENTINEL_STATUS=true

# ------------------------------------------------------------------------------
# PERFORMANCE BENCHMARKING
# ------------------------------------------------------------------------------

# Export performance benchmark metrics
EXPORT_BENCHMARK_METRICS=false
BENCHMARK_INTERVAL_SECONDS=300

# ------------------------------------------------------------------------------
# MULTI-TENANCY SUPPORT
# ------------------------------------------------------------------------------

# Track metrics per tenant (if using keyspace prefixes)
TRACK_TENANT_METRICS=true
TENANT_KEY_PREFIX_PATTERN=tenant:*:

# ------------------------------------------------------------------------------
# COMPLIANCE AND AUDIT
# ------------------------------------------------------------------------------

# Compliance tracking
COMPLIANCE_MODE=enabled
AUDIT_LOG_ACCESS=true
GDPR_COMPLIANCE=true

# ------------------------------------------------------------------------------
# DEVELOPMENT AND TESTING
# ------------------------------------------------------------------------------

# Development mode settings (disable in production)
# DEV_MODE=false
# MOCK_REDIS=false
# DRY_RUN=false

# ------------------------------------------------------------------------------
# DOCUMENTATION AND METADATA
# ------------------------------------------------------------------------------

EXPORTER_VERSION=4.6.0
EXPORTER_DESCRIPTION="Vulcan LLM Redis Metrics Exporter"
MAINTAINER="VulcanAMI DevOps Team"
SUPPORT_EMAIL="devops@vulcanami.io"
DOCUMENTATION_URL="https://docs.vulcanami.io/redis-monitoring"

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
