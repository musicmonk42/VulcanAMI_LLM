      "outlier_correction": ["inconsistent_data", "statistical_anomalies"],
      "format_standardization": ["format_errors", "encoding_issues"],
      "deduplication": ["duplicate_records", "redundant_data"],
      "normalization": ["inconsistent_format", "value_normalization"]
    },
    "priority_order": [
