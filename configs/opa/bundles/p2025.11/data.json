      "data_enrichment",
      "schema_inference",
      "missing_value_imputation",
      "outlier_correction",
      "format_standardization",
      "deduplication",
      "normalization"
    ],
    "strategy_mappings": {
      "auto_repair": ["syntax_errors", "format_errors"],
      "data_enrichment": ["incomplete_fields", "missing_metadata"],
      "schema_inference": ["schema_mismatch", "type_errors"],
