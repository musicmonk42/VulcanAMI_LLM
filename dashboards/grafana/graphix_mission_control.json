        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(unified_platform_requests_total{instance=~\"$instance\",status=~\"5..\"}[5m])) by (service)",
          "hide": false,
          "legendFormat": "Platform {{service}} 5xx",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Execution Error Rate",
      "type": "timeseries"
    },
