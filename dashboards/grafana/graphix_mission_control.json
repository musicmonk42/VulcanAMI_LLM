      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum(rate(execution_errors_total{instance=~\"$instance\"}[5m])) by (service)",
          "legendFormat": "{{service}} errors",
          "range": true,
          "refId": "A"
