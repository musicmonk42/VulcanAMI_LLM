  "version": "2.4.0",
  "metadata": {
    "description": "Core ontology for Graphix IR, mapping all node_type, edge_type, and semantic_type strings to globally unique URIs. This ensures semantic consistency across agents, prevents drift, and links to external ontologies for interoperability.",
    "base_uri": "https://graphix.ai/ontology/",
    "external_ontologies": {
      "schema_org": "https://schema.org/",
      "prov_o": "https://www.w3.org/TR/prov-o/",
      "wikidata": "https://www.wikidata.org/wiki/",
      "foaf": "http://xmlns.com/foaf/0.1/",
      "dcterms": "http://purl.org/dc/terms/"
    },
    "last_updated": "2025-01-15T10:30:00Z",
    "change_log": [
      {
        "version": "2.4.0",
        "date": "2025-01-15T10:30:00Z",
        "changes": [
          "Fixed duplicate external references",
          "Moved MetaEdge from node_types to edge_types",
          "Improved external mappings with more specific references",
          "Added JSON Schema definitions",
          "Added deprecation mechanism",
          "Added semantic types for quantum, cryptographic, and distributed operations",
          "Added lifecycle status field to all types"
        ]
      },
      {
        "version": "2.3.0",
        "date": "2024-12-01T00:00:00Z",
        "changes": [
          "Initial stable release"
        ]
      }
    ],
